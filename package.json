{
  "name": "platform",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "concurrently -k -n relayemail,statuslayer,api -c blue,green,yellow \"pnpm --filter @platform/relayemail-web dev\" \"pnpm --filter @platform/statuslayer-web dev\" \"go -C ./services/go run ./cmd/platform-api\"",
    "dev:web": "concurrently -k -n relayemail,statuslayer -c blue,green \"pnpm --filter @platform/relayemail-web dev\" \"pnpm --filter @platform/statuslayer-web dev\"",
    "dev:relayemail": "pnpm --filter @platform/relayemail-web dev",
    "dev:statuslayer": "pnpm --filter @platform/statuslayer-web dev",
    "dev:api": "go -C ./services/go run ./cmd/platform-api",
    "build": "pnpm -r --if-present build && go -C ./services/go build ./...",
    "build:web": "pnpm -r --if-present build",
    "build:api": "go -C ./services/go build ./...",
    "typecheck": "pnpm -r --if-present typecheck",
    "check": "pnpm -r --if-present typecheck && env GOCACHE=/tmp/platform-go-build go -C ./services/go test ./..."
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "vite": "^8.0.1"
  }
}